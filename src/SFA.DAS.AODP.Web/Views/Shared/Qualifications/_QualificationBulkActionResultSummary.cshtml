@using SFA.DAS.AODP.Web.Models.BulkActions
@model QualificationBulkActionResultViewModel?

@if (Model == null || !Model.HasAnyErrors)
{
    return;
}

<div class="govuk-notification-banner govuk-notification-banner--warning" role="alert">
    <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title">
            @(Model.UpdatedCount == 0 ? "Bulk update failed" : "Bulk update completed with some issues")
        </h2>
    </div>
    <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">
            Updated @Model.UpdatedCount of @Model.RequestedCount to “@Model.ProcessStatusName”.
        </p>

        @if (Model.MissingQualifications.Any())
        {
            <details class="govuk-details">
                <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">
                        Qualifications not found (@Model.MissingQualifications.Count)
                    </span>
                </summary>
                <div class="govuk-details__text">
                    <table class="govuk-table">
                        <thead class="govuk-table__head">
                            <tr class="govuk-table__row">
                                <th class="govuk-table__header">QAN</th>
                                <th class="govuk-table__header">Details</th>
                            </tr>
                        </thead>
                        <tbody class="govuk-table__body">
                            @foreach (var e in Model.MissingQualifications)
                            {
                                <tr class="govuk-table__row">
                                    <td class="govuk-table__cell">@e.Qan</td>
                                    <td class="govuk-table__cell">@e.Title</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </details>
        }

        @if (Model.StatusUpdateFailed.Any())
        {
            <details class="govuk-details">
                <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">
                        Status could not be updated (@Model.StatusUpdateFailed.Count)
                    </span>
                </summary>
                <div class="govuk-details__text">
                    <table class="govuk-table">
                        <thead class="govuk-table__head">
                            <tr class="govuk-table__row">
                                <th class="govuk-table__header">QAN</th>
                                <th class="govuk-table__header">Details</th>
                            </tr>
                        </thead>
                        <tbody class="govuk-table__body">
                            @foreach (var e in Model.StatusUpdateFailed)
                            {
                                <tr class="govuk-table__row">
                                    <td class="govuk-table__cell">@e.Qan</td>
                                    <td class="govuk-table__cell">@e.Title</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </details>
        }

        @if (Model.HistoryUpdateFailed.Any())
        {
            <details class="govuk-details">
                <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">
                        Status updated but history could not be added (@Model.HistoryUpdateFailed.Count)
                    </span>
                </summary>
                <div class="govuk-details__text">
                    <table class="govuk-table">
                        <thead class="govuk-table__head">
                            <tr class="govuk-table__row">
                                <th class="govuk-table__header">QAN</th>
                                <th class="govuk-table__header">Details</th>
                            </tr>
                        </thead>
                        <tbody class="govuk-table__body">
                            @foreach (var e in Model.HistoryUpdateFailed)
                            {
                                <tr class="govuk-table__row">
                                    <td class="govuk-table__cell">@e.Qan</td>
                                    <td class="govuk-table__cell">@e.Title</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </details>
        }
    </div>
</div>