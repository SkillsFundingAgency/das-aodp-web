@using SFA.DAS.AODP.Web.Models.Import
@using SFA.DAS.AODP.Web.Views.Shared
@model ImportRequestViewModel
@{
    ViewData["Title"] = "Import Data";

    var backLinkModel = new BackLinkModel
    {
        Action = "Index",
        Controller = "Home",
        Area = "Review",
        Text = "Back to qualifications"
    };
}

<partial name="~/Views/Shared/_NotificationPartial.cshtml" />

@await Html.PartialAsync("_BackLinkPartial", backLinkModel)

<h1 class="govuk-heading-1">Qualifications you need to import</h1>

<form asp-controller="Import" asp-action="SelectImport" asp-area="Admin" method="post">

    @Html.AntiForgeryToken()

    <div class="govuk-form-group">
        <govuk-radios for="ImportType">
            <govuk-radios-fieldset>
                <govuk-radios-fieldset-legend is-page-heading="false" class="govuk-fieldset__legend--s">
                    <div class="govuk-hint" id="ImportType-hint">
                        Select one option
                    </div>
                </govuk-radios-fieldset-legend>

                @Html.RenderPartialAsync("Validation/_RadioValidationPartial", nameof(Model.ImportType))

                <govuk-radios-item value="Regulated Qualifications">
                    Regulated Qualifications
                    <govuk-radios-hint class="govuk-hint govuk-radios__hint govuk-!-static-padding-0">
                        This includes qualifications with changes from Ofqual
                    </govuk-radios-hint>
                </govuk-radios-item>
                <govuk-radios-item value="Funded Qualifications">
                    Funded Qualifications
                    <govuk-radios-hint class="govuk-hint govuk-radios__hint govuk-!-static-padding-0">
                        This includes both currently approved and archived qualifications
                    </govuk-radios-hint>
                </govuk-radios-item>
                <govuk-radios-item value="Defunding list">
                    Defunding list
                </govuk-radios-item>
                <govuk-radios-item value="Pldns">
                    Policy last date for new starters (PLDNS) list
                </govuk-radios-item>
                                
               
            </govuk-radios-fieldset>
        </govuk-radios>
    </div>

    <div class="govuk-form-group">
        <govuk-button type="submit">Continue</govuk-button>
        <a class="govuk-button govuk-button--secondary" asp-action="Index" asp-controller="Home" asp-area="Review">
            Back to qualifications
        </a>
    </div>
</form>