@using SFA.DAS.AODP.Web.Models.Import
@model ImportViewModel

@using System.Security.Claims
@{
	ViewData["Title"] = "Import Data";
}

<div class="govuk-width-container">
	<main class="govuk-main-wrapper">
		<div class="govuk-grid-row">
			<div class="govuk-grid-column-two-thirds">

				    <form asp-controller="Import" asp-action="CheckProgress" method="post">

                     @Html.AntiForgeryToken()

                    <div class="govuk-form-group">
						<div class="govuk-grid-row">
							<div class="govuk-grid-column-full">
								<p><strong>Importing regulated qualifications</strong></p>
								<p>Started on DD/MM/YYYY at HH:MM:SS by [Name of user] </p>
							</div>
						</div>
					</div>

                    <govuk-button type="submit">Check progress of import</govuk-button>

                </form>

			</div>
        </div>
	</main>
</div>


