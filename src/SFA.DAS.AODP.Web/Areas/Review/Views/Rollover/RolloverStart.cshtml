@model SFA.DAS.AODP.Web.Areas.Review.Models.Rollover.RolloverStartViewModel
@{
    ViewData["Title"] = "Which stage of the rollover process do you need to do?";
}

<partial name="~/Views/Shared/_NotificationPartial.cshtml" />

<a class="govuk-back-link" asp-area="Review" asp-action="Index" asp-controller="Home" asp-area="Review">Back</a>

<h1 class="govuk-heading-xl govuk-!-margin-bottom-2">@ViewData["Title"]</h1>
                    <h1 class="govuk-heading-xl">@ViewData["Title"]</h1>
<form asp-area="Review" asp-controller="Rollover" asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <div class="govuk-form-group">
        <govuk-radios asp-for="@Model.SelectedProcess">
            <govuk-radios-fieldset>
                <govuk-radios-fieldset-legend is-page-heading="false" class="govuk-fieldset__legend--s"></govuk-radios-fieldset-legend>
                            <govuk-radios-fieldset>
                                <govuk-radios-fieldset-legend is-page-heading="false" class="govuk-fieldset__legend--s"></govuk-radios-fieldset-legend>

                @Html.RenderPartialAsync("Validation/_RadioValidationPartial", nameof(Model.SelectedProcess))

                <govuk-radios-item value="InitialSelection">Initial selection of qualifications to be checked for rollover</govuk-radios-item>
                <govuk-radios-item value="FinalUpload">Final upload of a file with the QA'd decision for rollover</govuk-radios-item>
            </govuk-radios-fieldset>
        </govuk-radios>
    </div>

    <govuk-button type="submit">Continue</govuk-button>
</form>