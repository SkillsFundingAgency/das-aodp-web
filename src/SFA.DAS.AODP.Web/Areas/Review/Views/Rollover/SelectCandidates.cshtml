@using SFA.DAS.AODP.Web.Areas.Review.Controllers
@using SFA.DAS.AODP.Web.Views.Shared
@model SFA.DAS.AODP.Web.Areas.Review.Models.Rollover.RolloverSelectCandidatesViewModel
@{
    ViewData["Title"] = "How do you want to select candidates for rollover?";

    var backLinkModel = new BackLinkModel
    {
        Action = @Model.ReturnUrl == nameof(RolloverController.PreviousFile) ? nameof(RolloverController.PreviousFile) : nameof(RolloverController.CheckData),
        Controller = "Rollover",
        Area = "Review"
    };
}

@await Html.PartialAsync("_BackLinkPartial", backLinkModel)

<partial name="~/Views/Shared/_NotificationPartial.cshtml" />

<form asp-area="Review" asp-controller="Rollover" asp-action="SelectCandidates" method="post">
    @Html.AntiForgeryToken()

    <input asp-for="ReturnUrl" type="hidden" />

        <govuk-radios asp-for="@Model.SelectedOption">
            <govuk-radios-fieldset>
                <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">@ViewData["Title"]</govuk-radios-fieldset-legend>

                @Html.RenderPartialAsync("Validation/_RadioValidationPartial", nameof(Model.SelectedOption))

                <govuk-radios-item value="ImportAList">Import a list</govuk-radios-item>
                <govuk-radios-item value="GenerateAList">Generate a list of candidates by selecting level, type, SSA and AO</govuk-radios-item>
            </govuk-radios-fieldset>
        </govuk-radios>

    <govuk-button type="submit">Continue</govuk-button>

</form>
